{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd jjp-agent && npm install --legacy-peer-deps"
  },
  "deploy": {
    "startCommand": "cd jjp-agent && node src/index.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
